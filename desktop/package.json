{
  "name": "kaptnotes-desktop",
  "version": "1.0.0",
  "description": "KaptNotes — Application desktop Ramery",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ramery.kaptnotes",
    "productName": "KaptNotes",
    "win": {
      "target": "portable",
      "signingHashAlgorithms": null
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
